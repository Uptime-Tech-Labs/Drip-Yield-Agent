# ─── Chain RPCs ───────────────────────────────────────────────────────────────
MAINNET_RPC_URL=https://eth-mainnet.example
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Keys (DO NOT COMMIT REAL VALUES) ─────────────────────────────────────────
OWNER_PRIVATE_KEY=0xYOUR_OWNER_PRIVATE_KEY
AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY

# ─── Agent Identity ───────────────────────────────────────────────────────────
AGENT_WALLET_ADDRESS=0xYourAgentAddress
AGENT_ADDRESS=0xYourAgentAddress
MAINNET_AGENT_ADDRESS=0xYourAgentAddress
BASE_AGENT_ADDRESS=0xYourAgentAddress

# ─── Mainnet Yield Vault Deploy Params ────────────────────────────────────────
# Canonical mainnet wstETH:
# 0x7f39C581F595B53c5cb19bD0b3f8dA6c935E2Ca0
MAINNET_WSTETH_ADDRESS=0x7f39C581F595B53c5cb19bD0b3f8dA6c935E2Ca0
# Example: 0.01 wstETH (18 decimals)
MAINNET_MAX_DRAW_PER_TX=10000000000000000

# ─── Base Spending Vault Deploy Params ────────────────────────────────────────
# Base USDC:
# 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
BASE_SPEND_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Example: 1 USDC per tx (6 decimals)
BASE_MAX_DRAW_PER_TX=1000000
BASE_GAME_PAYMENT_ADDRESS=0xGamePaymentRecipient

# ─── Deployed Contract Addresses (fill after deployment) ─────────────────────
MAINNET_VAULT_ADDRESS=0xYourMainnetVaultAddress
BASE_SPENDING_VAULT_ADDRESS=0xYourBaseSpendingVaultAddress

# Mainnet drawYield recipient (defaults to AGENT_WALLET_ADDRESS — must be whitelisted)
# MAINNET_DRAW_RECIPIENT=0xYourAgentOrBridge

# Optional Uniswap V3 fee tiers on Ethereum (uint24, e.g. 500 = 0.05%)
# MAINNET_UNISWAP_FEE_WSTETH_WETH=500
# MAINNET_UNISWAP_FEE_WETH_USDC=500

# ─── Optional Explorer / API Keys ─────────────────────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key
BASESCAN_API_KEY=your_basescan_api_key

# ─── Across bridge (USDC Ethereum → Base) ─────────────────────────────────────
# Optional 2-byte hex integrator ID for production: https://github.com/across-protocol/skills
# ACROSS_INTEGRATOR_ID=0xdead

# ─── Game API (x402) — https://play.0000402.xyz/ (valid public TLS; default fetch is fine) ──
GAME_API_BASE_URL=https://play.0000402.xyz
# Prefer IPv4 in DNS (avoids Node fetch AggregateError when only IPv4 works). Set 0 to use Node default.
# GAME_DNS_IPV4_FIRST=1
# Only for a custom game host with a cert Node rejects (self-signed, etc.). Leave 0 for play.0000402.xyz
GAME_TLS_INSECURE=0
# Default: undici for game HTTP. Set 1 to use Node fetch if undici misbehaves.
# GAME_USE_NODE_FETCH=0
# Set to 1 to skip play-game in automated runs (default: play when funded).
# DRIPAGENT_SKIP_PLAY=0

# ─── LLM Provider ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ─── Mastra memory (LibSQL file — created under ./data/) ──────────────────────
# MASTRA_MEMORY_URL=file:./data/mastra-memory.db
# MASTRA_MEMORY_RESOURCE_ID=dripagent
# MASTRA_MEMORY_THREAD_ID=dripagent-main

# ─── The Synthesis hackathon (https://synthesis.md/skill.md) ──────────────────
# Agent self-registration: fill the block below once; then run synthesis-registration-advance.
# Only human step: email OTP (6 digits) or one tweet URL — set SYNTHESIS_EMAIL_OTP or SYNTHESIS_SOCIAL_TWEET_URL and re-run.
# SYNTHESIS_VERIFY_METHOD=email
# SYNTHESIS_AGENT_NAME=Drip Yield Agent
# SYNTHESIS_AGENT_DESCRIPTION=Spend yield on Base via x402.
# SYNTHESIS_AGENT_HARNESS=cursor
# SYNTHESIS_AGENT_MODEL=claude-sonnet-4-5
# SYNTHESIS_HUMAN_NAME=Jane Doe
# SYNTHESIS_HUMAN_EMAIL=jane@example.com
# SYNTHESIS_HUMAN_SOCIAL_MEDIA_HANDLE=@jane
# SYNTHESIS_HUMAN_BACKGROUND=Builder
# SYNTHESIS_HUMAN_CRYPTO_EXPERIENCE=a little
# SYNTHESIS_HUMAN_AI_AGENT_EXPERIENCE=yes
# SYNTHESIS_HUMAN_CODING_COMFORT=7
# SYNTHESIS_HUMAN_PROBLEM_TO_SOLVE=On-chain yield to usable USDC for agents
# Optional: SYNTHESIS_TEAM_CODE= (12-char hex to join a team)
# SYNTHESIS_SOCIAL_HANDLE=username (required if SYNTHESIS_VERIFY_METHOD=social)
# After first advance run, paste OTP from email:
# SYNTHESIS_EMAIL_OTP=123456
# SYNTHESIS_RESEND_EMAIL_OTP=1
# Social path: SYNTHESIS_SOCIAL_TWEET_URL=https://x.com/...
# After registration completes:
# SYNTHESIS_API_KEY=sk-synth-...
# SYNTHESIS_CREDENTIALS_FILE=.synthesis-credentials
# SYNTHESIS_REGISTRATION_FILE=.synthesis-registration.json

# ─── The Synthesis — project submission (https://synthesis.devfolio.co/submission/skill.md) ──
# Required: public GitHub repo (open source by deadline).
# SYNTHESIS_PROJECT_REPO_URL=https://github.com/you/dripagent
# Optional: comma-separated track UUIDs (default: stETH Agent Treasury)
# SYNTHESIS_PROJECT_TRACK_UUIDS=5e445a077b5248e0974904915f76e1a0
# SYNTHESIS_PROJECT_NAME=Drip Yield Agent
# SYNTHESIS_SELF_CUSTODY_ADDRESS=0x... (defaults to registered wallet / AGENT_WALLET_ADDRESS)
# npm run synthesis:submit

